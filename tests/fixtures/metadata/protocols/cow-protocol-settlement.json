{
  "$schema": "../../erc7730-v1.schema.json",
  "context": {
    "contract": {
      "address": "0x9008D19f58AAbD9eD0D60971565AA8510560ab41",
      "chainId": 1,
      "name": "CoW Protocol GPv2 Settlement",
      "abi": [
        {
          "type": "function",
          "name": "settle",
          "selector": "0x13d79a0b",
          "inputs": [
            { "name": "tokens", "type": "address[]" },
            { "name": "clearingPrices", "type": "uint256[]" },
            {
              "name": "trades",
              "type": "tuple[]",
              "components": [
                { "name": "sellTokenIndex", "type": "uint256" },
                { "name": "buyTokenIndex", "type": "uint256" },
                { "name": "receiver", "type": "address" },
                { "name": "sellAmount", "type": "uint256" },
                { "name": "buyAmount", "type": "uint256" },
                { "name": "validTo", "type": "uint32" },
                { "name": "appData", "type": "bytes32" },
                { "name": "feeAmount", "type": "uint256" },
                { "name": "flags", "type": "uint256" },
                { "name": "executedAmount", "type": "uint256" },
                { "name": "signature", "type": "bytes" }
              ]
            },
            {
              "name": "interactions",
              "type": "tuple[][3]",
              "components": [
                { "name": "target", "type": "address" },
                { "name": "value", "type": "uint256" },
                { "name": "callData", "type": "bytes" }
              ]
            }
          ]
        },
        {
          "type": "function",
          "name": "setPreSignature",
          "selector": "0xec6cb13f",
          "inputs": [
            { "name": "orderUid", "type": "bytes" },
            { "name": "signed", "type": "bool" }
          ]
        },
        {
          "type": "function",
          "name": "invalidateOrder",
          "selector": "0x2d9a3f24",
          "inputs": [
            { "name": "orderUid", "type": "bytes" }
          ]
        }
      ]
    }
  },
  "display": {
    "formats": {
      "settle(address[],uint256[],(uint256,uint256,address,uint256,uint256,uint32,bytes32,uint256,uint256,uint256,bytes)[],(address,uint256,bytes)[][3])": {
        "intent": "Settle CoW batch auction",
        "interpolatedIntent": "Settle batch with {trades.length} trades",
        "fields": [
          { "path": "tokens", "label": "Tokens", "format": "array" },
          { "path": "trades", "label": "Trades", "format": "array" }
        ]
      },
      "settle(address[],uint256[],tuple[],tuple[][3])": {
        "intent": "Settle CoW batch auction",
        "interpolatedIntent": "Settle batch with {trades.length} trades",
        "fields": [
          { "path": "tokens", "label": "Tokens", "format": "array" },
          { "path": "trades", "label": "Trades", "format": "array" }
        ]
      },
      "setPreSignature(bytes,bool)": {
        "intent": "Authorize CoW order",
        "interpolatedIntent": "Authorize CoW order",
        "fields": [
          { "path": "orderUid.[0:31]", "label": "Order Digest", "format": "hex" },
          { "path": "orderUid.[32:51]", "label": "Order Owner", "format": "address" },
          { "path": "orderUid.[52:55]", "label": "Valid Until", "format": "timestamp" },
          { "path": "orderUid", "label": "Order UID", "format": "hex" },
          { "path": "signed", "label": "Signed", "format": "boolean" }
        ]
      },
      "invalidateOrder(bytes)": {
        "intent": "Cancel CoW order",
        "interpolatedIntent": "Cancel CoW order",
        "fields": [
          { "path": "orderUid.[0:31]", "label": "Order Digest", "format": "hex" },
          { "path": "orderUid.[32:51]", "label": "Order Owner", "format": "address" },
          { "path": "orderUid.[52:55]", "label": "Valid Until", "format": "timestamp" },
          { "path": "orderUid", "label": "Order UID", "format": "hex" }
        ]
      }
    }
  }
