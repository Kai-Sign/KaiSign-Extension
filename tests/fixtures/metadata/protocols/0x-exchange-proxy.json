{
  "context": {
    "contract": {
      "address": "0xdef1c0ded9bec7f1a1670819833240f027b25eff",
      "chainId": 1,
      "name": "0x Exchange Proxy",
      "abi": [
        {
          "type": "function",
          "name": "transformERC20",
          "selector": "0x415565b0",
          "inputs": [
            { "name": "inputToken", "type": "address" },
            { "name": "outputToken", "type": "address" },
            { "name": "inputTokenAmount", "type": "uint256" },
            { "name": "minOutputTokenAmount", "type": "uint256" },
            {
              "name": "transformations",
              "type": "tuple[]",
              "components": [
                { "name": "deploymentNonce", "type": "uint32" },
                { "name": "data", "type": "bytes" }
              ]
            }
          ]
        },
        {
          "type": "function",
          "name": "fillRfqOrder",
          "selector": "0xaa77476c",
          "inputs": [
            { "name": "order", "type": "tuple", "components": [] },
            { "name": "signature", "type": "tuple", "components": [] },
            { "name": "takerTokenFillAmount", "type": "uint128" }
          ]
        },
        {
          "type": "function",
          "name": "fillLimitOrder",
          "selector": "0xdac748d4",
          "inputs": [
            { "name": "order", "type": "tuple", "components": [] },
            { "name": "signature", "type": "tuple", "components": [] },
            { "name": "takerTokenFillAmount", "type": "uint128" }
          ]
        }
      ]
    }
  },
  "display": {
    "formats": {
      "transformERC20(address,address,uint256,uint256,tuple[])": {
        "intent": "Swap via 0x",
        "interpolatedIntent": "Swap {inputTokenAmount} for at least {minOutputTokenAmount}",
        "fields": [
          { "path": "inputToken", "label": "From Token", "format": "addressName" },
          { "path": "outputToken", "label": "To Token", "format": "addressName" },
          { "path": "inputTokenAmount", "label": "Amount In", "format": "tokenAmount", "params": { "tokenPath": "inputToken" } },
          { "path": "minOutputTokenAmount", "label": "Min Amount Out", "format": "tokenAmount", "params": { "tokenPath": "outputToken" } }
        ]
      },
      "fillRfqOrder(tuple,tuple,uint128)": {
        "intent": "Fill RFQ order via 0x",
        "interpolatedIntent": "Fill RFQ order for {takerTokenFillAmount}",
        "fields": [
          { "path": "takerTokenFillAmount", "label": "Fill Amount", "format": "raw" }
        ]
      },
      "fillLimitOrder(tuple,tuple,uint128)": {
        "intent": "Fill limit order via 0x",
        "interpolatedIntent": "Fill limit order for {takerTokenFillAmount}",
        "fields": [
          { "path": "takerTokenFillAmount", "label": "Fill Amount", "format": "raw" }
        ]
      }
    }
  }
}
