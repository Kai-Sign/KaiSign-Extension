{
  "name": "kaisign-decoder-tests",
  "version": "1.0.0",
  "description": "Comprehensive decoder test suite for KaiSign Extension",
  "main": "run-all-tests.js",
  "type": "module",
  "scripts": {
    "test": "node run-all-tests.js",
    "test:live-sepolia": "KAISIGN_LIVE_SEPOLIA=1 node run-all-tests.js --suite=onchain-verifier",
    "sweep:verified-abi": "node scripts/sweep-verified-abi.js",
    "sample:recent-mainnet": "node scripts/sample-recent-mainnet.js",
    "generate:sample-metadata": "node scripts/generate-metadata-from-sample.js",
    "fetch-metadata": "node scripts/fetch-metadata.js",
    "fetch-transactions": "node scripts/fetch-transactions.js",
    "local-server": "node local-server.js",
    "audit-metadata": "node scripts/generate-missing-list.js"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "ethers": "^6.9.0",
    "express": "^4.21.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
