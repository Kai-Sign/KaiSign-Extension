{
  "manifest_version": 3,
  "name": "KaiSign",
  "version": "1.2.1",
  "description": "Transaction analysis and clear signing for Ethereum wallets",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "options_page": "options.html",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "https://api.studio.thegraph.com/*",
    "https://api.sepolia.blobscan.com/*",
    "https://api.gateway.ethswarm.org/*",
    "https://storage.googleapis.com/*",
    "https://kai-sign-production.up.railway.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["subgraph-metadata.js", "runtime-registry.js", "metadata.js", "eip712-decoder.js", "decode.js", "recursive-decoder.js", "advanced-decoder.js", "content-script.js"],
      "run_at": "document_end",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["bridge-script.js"],
      "run_at": "document_end",
      "world": "ISOLATED"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup.html"
  }
}
