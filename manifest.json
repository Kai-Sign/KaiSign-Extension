{
  "manifest_version": 3,
  "name": "KaiSign",
  "version": "1.1.0",
  "description": "Transaction analysis and clear signing for Ethereum wallets",
  "permissions": [
    "activeTab",
    "storage",
    "unlimitedStorage"
  ],
  "options_page": "options.html",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "https://api.studio.thegraph.com/*",
    "https://api.sepolia.blobscan.com/*",
    "https://api.gateway.ethswarm.org/*",
    "https://storage.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["registry-loader.js", "metadata.js", "decode.js", "advanced-decoder.js", "content-script.js"],
      "run_at": "document_end",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["bridge-script.js"],
      "run_at": "document_end",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "local-metadata/manifest.json",
        "local-metadata/registry/*.json",
        "local-metadata/**/*.json"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}